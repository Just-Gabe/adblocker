{
    "manifest_version": 2,
    "name": "AllBlocker",
    "version": "1.0",
    "description": "Bloqueia tudo sem dó",
    "icons": {
        "48": "icons/icon.svg"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "allblocker@wpx.softwares.com",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "*://facebook.com/*",
                "*://*.facebook.com/*",
                "*://reddit.com/*",
                "*://*.reddit.com/*",
                "*://instagram.com/*",
                "*://*.instagram.com/*",
                "*://twitter.com/*",
                "*://*.twitter.com/*",
                "*://*.bbc.com/*",
                "*://*.cnn.com/*",
                "*://*.wordpress.com/*",
                "*://*.blogspot.com/*"
            ],
            "js": [
                "adblock.js"
            ],
            "run_at": "document_start"
        }
    ]
}